# --- Database ---
# Local / TCP connection:
MYSQL_HOST=127.0.0.1
DB_PORT=3306
# Cloud Run + Cloud SQL: leave MYSQL_HOST/DB_PORT unset and instead set:
# INSTANCE_CONNECTION_NAME=your-project:us-central1:collabora-db
MYSQL_USER=collabora
MYSQL_PASSWORD=
MYSQL_DATABASE=collabora

# --- Auth ---
JWT_SECRET=change-me

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173

# --- Google Cloud Storage ---
GCS_BUCKET_NAME=your-bucket-name
# Only needed OUTSIDE Cloud Run (local dev). On Cloud Run, the service
# account provides credentials automatically — omit this.
# GOOGLE_APPLICATION_CREDENTIALS=./gcpbucketkey.json

# --- Email (Gmail SMTP) ---
# If SMTP_USER/SMTP_PASS are unset, emails are silently disabled (logged only).
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-google-app-password   # NOT your normal Gmail password
# Optional overrides:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# MAIL_FROM_NAME=Collabora
# MAIL_FROM=you@gmail.com
# Frontend URL used for button links in emails:
APP_URL=http://localhost:5173
